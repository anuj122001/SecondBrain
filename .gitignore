# ==============================================================
#  Second Brain — .gitignore
# ==============================================================

# ---------------------------------------------------------------
# SECRETS & ENVIRONMENT  (never commit these)
# ---------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx

# ---------------------------------------------------------------
# DEPENDENCIES
# ---------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------------------------------------------------------------
# BUILD OUTPUTS
# ---------------------------------------------------------------
dist/
build/
out/
.vite/
*.tsbuildinfo

# ---------------------------------------------------------------
# LOGS
# ---------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------
# RUNTIME & TEMP
# ---------------------------------------------------------------
tmp/
temp/
.tmp/
*.tmp
*.temp
uploads/            # local file uploads (use S3 in prod)
coverage/           # test coverage reports
.nyc_output/

# ---------------------------------------------------------------
# OS & EDITOR
# ---------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------
# AWS & CLOUD CREDENTIALS
# ---------------------------------------------------------------
.aws/
credentials
aws-exports.js

# ---------------------------------------------------------------
# DOCKER  (keep docker-compose.yml but ignore local overrides)
# ---------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml

# ---------------------------------------------------------------
# MISC
# ---------------------------------------------------------------
.cache/
.parcel-cache/
*.local
