# ==============================================================
#  Second Brain — backend .gitignore
# ==============================================================

# ---------------------------------------------------------------
# SECRETS — never commit these
# ---------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key

# ---------------------------------------------------------------
# DEPENDENCIES
# ---------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------
# LOGS
# ---------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ---------------------------------------------------------------
# RUNTIME & TEMP
# ---------------------------------------------------------------
tmp/
temp/
uploads/
coverage/
.nyc_output/

# ---------------------------------------------------------------
# OS & EDITOR
# ---------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ---------------------------------------------------------------
# AWS
# ---------------------------------------------------------------
.aws/
credentials
